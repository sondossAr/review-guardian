@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

actor "Utilisateur final" as User
actor "Administrateur / Intégrateur API" as Admin

rectangle "Review Guardian" {
  usecase "Soumettre un avis\n(mode classique)" as UC1
  usecase "Consulter le résultat\nd'analyse" as UC2
  usecase "Analyser un avis\nen mode chat" as UC3
  usecase "Consulter les détails\nd'analyse" as UC4
  usecase "Analyser des avis\nen lot via API" as UC5
  usecase "Consulter la\ndocumentation API" as UC6
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4

Admin --> UC5
Admin --> UC6

UC2 ..> UC1 : <<include>>
UC4 ..> UC2 : <<extend>>
@enduml
